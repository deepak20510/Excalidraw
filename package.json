{
  "name": "draw-app",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "build:frontend": "pnpm --filter excalidraw-frontend build",
    "start:frontend": "pnpm --filter excalidraw-frontend start",
    "build:http": "pnpm --filter http-backend build",
    "start:http": "pnpm --filter http-backend start",
    "build:ws": "pnpm --filter ws-backend build",
    "start:ws": "pnpm --filter ws-backend start",
    "migrate:db": "pnpm --filter @repo/db exec prisma migrate deploy",
    "generate:db": "pnpm --filter @repo/db exec prisma generate"
  },
  "dependencies": {
    "prisma": "^7.8.0",
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
